{{ ansible_managed | comment }}

node.name: "{{ elasticsearch_nodename }}"
path.data: {{ elasticsearch_datapath }}
path.logs: {{ elasticsearch_logpath }}
cluster.name: "{{ elasticsearch_clustername }}"
{% if elasticsearch_network_host is defined %}
{% if elasticsearch_network_host is string %}
network.host: [ {{ elasticsearch_network_host }} ]
{% else %}
network.host: {{ elasticsearch_network_host | to_json }}
{% endif %}
{% else %}
network.host: [ "_local_", "_site_" ]
{% endif %}
{% if elasticstack_elasticsearch_http_port is defined %}
http.port: "{{ elasticstack_elasticsearch_http_port }}"
{% endif %}
{% if elasticsearch_transport_port is defined %}
transport.port: "{{ elasticsearch_transport_port }}"
{% endif %}
{% if elasticsearch_http_publish_host is defined %}
http.publish_host: "{{ elasticsearch_http_publish_host }}"
{% endif %}
{% if elasticsearch_http_publish_port is defined %}
http.publish_port: {{ elasticsearch_http_publish_port }}
{% endif %}

{% if elasticsearch_node_types is defined %}
node.roles: {{ elasticsearch_node_types | to_json }}
{% endif %}

{% if groups[elasticstack_elasticsearch_group_name] | length == 1 %}
discovery.type: single-node
{% endif %}

{# Quickfix to override seed_hosts. Otherwise all nodes, not only master nodes are added to seed_hosts #}
{% if elasticsearch_seed_hosts is defined %}
discovery.seed_hosts: {{ elasticsearch_seed_hosts | to_json }}
{% else %}
{% if groups[elasticstack_elasticsearch_group_name] | length > 1 %}
discovery.seed_hosts: [ {% for host in groups[elasticstack_elasticsearch_group_name]  %}
"{{ hostvars[host].ansible_host | default(hostvars[host].inventory_hostname) }}"{% if not loop.last %},{% endif %}
{% endfor %} ]
{% endif %}
{% endif %}

{% if not elasticsearch_cluster_set_up | bool and groups[elasticstack_elasticsearch_group_name] | length > 1 %}
{% if elasticsearch_node_types is defined %}
cluster.initial_master_nodes: [ {% for host in groups['elasticsearch_role_master']  %}
"{{ hostvars[host]['elasticsearch_nodename'] }}"{% if not loop.last %},{% endif %}
{% endfor %} ]
{% else %}
cluster.initial_master_nodes: [ {% for host in groups[elasticstack_elasticsearch_group_name]  %}
"{{ hostvars[host]['elasticsearch_nodename'] }}"{% if not loop.last %},{% endif %}
{% endfor %} ]
{% endif %}
{% endif %}

{% if elasticstack_temperature is defined %}
node.attr.temp: "{{ elasticstack_temperature }}"
{% endif %}
xpack.ml.enabled: {{ elasticsearch_ml_enabled }}
{% if elasticsearch_security | bool %}
xpack.security.enabled: true
{% if elasticsearch_security_enrollment is defined %}
xpack.security.enrollment.enabled: {{ elasticsearch_security_enrollment }}
{% endif %}
xpack.security.transport.ssl.enabled: true
xpack.security.transport.ssl.verification_mode: {{ elasticsearch_ssl_verification_mode }}
{% if elasticsearch_cert_source == 'external' %}
{%   if _elasticsearch_transport_cert_format | default('pem') == 'pem' %}
xpack.security.transport.ssl.certificate: certs/{{ inventory_hostname }}-transport.crt
xpack.security.transport.ssl.key: certs/{{ inventory_hostname }}-transport.key
{%     if _elasticsearch_external_has_ca | default(false) | bool %}
xpack.security.transport.ssl.certificate_authorities: ["certs/ca.crt"]
{%     endif %}
{%   else %}
xpack.security.transport.ssl.keystore.path: certs/{{ inventory_hostname }}-transport.p12
xpack.security.transport.ssl.truststore.path: certs/{{ inventory_hostname }}-transport.p12
{%   endif %}
{% else %}
xpack.security.transport.ssl.keystore.path: certs/{{ inventory_hostname_short }}.p12
xpack.security.transport.ssl.truststore.path: certs/{{ inventory_hostname_short }}.p12
{% endif %}
{% if elasticsearch_http_security | bool %}
xpack.security.http.ssl.enabled: true
{% if elasticsearch_cert_source == 'external' %}
{%   if _elasticsearch_http_cert_format | default('pem') == 'pem' %}
xpack.security.http.ssl.certificate: certs/{{ inventory_hostname }}-http.crt
xpack.security.http.ssl.key: certs/{{ inventory_hostname }}-http.key
{%     if _elasticsearch_external_has_ca | default(false) | bool %}
xpack.security.http.ssl.certificate_authorities: ["certs/ca.crt"]
{%     endif %}
{%   else %}
xpack.security.http.ssl.keystore.path: certs/{{ inventory_hostname }}-http.p12
xpack.security.http.ssl.truststore.path: certs/{{ inventory_hostname }}-http.p12
{%   endif %}
{% else %}
{% if elasticsearch_http_ssl_keystore_path | default('', true) | length > 0 %}
xpack.security.http.ssl.keystore.path: {{ elasticsearch_http_ssl_keystore_path }}
{% else %}
xpack.security.http.ssl.keystore.path: certs/{{ inventory_hostname_short }}.p12
{% endif %}
xpack.security.http.ssl.truststore.path: certs/{{ inventory_hostname_short }}.p12
{% endif %}
{% endif %}
{% endif %}
{% if not elasticsearch_security | bool %}
xpack.security.enabled: false
{% endif %}

{% if elasticsearch_memory_lock | bool %}
bootstrap.memory_lock: true
{% endif %}

{% if elasticsearch_fs_repo is defined %}
path:
  repo:
{% for path in elasticsearch_fs_repo %}
    - {{ path }}

{% endfor %}
{% endif %}

{# Filter elasticsearch_extra_config to remove keys already managed by dedicated role variables #}
{# _elasticsearch_managed_keys is defined in vars/main.yml #}
{% if elasticsearch_extra_config is defined and elasticsearch_extra_config %}
{%   set _filtered = elasticsearch_extra_config | dict2items | rejectattr('key', 'in', _elasticsearch_managed_keys) | list | items2dict %}
{%   if _filtered %}
{{ _filtered | to_nice_yaml(indent=2, sort_keys=False) }}
{%   endif %}
{% endif %}
