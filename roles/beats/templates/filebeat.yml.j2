{{ ansible_managed | comment }}

filebeat.inputs:

{% if beats_filebeat_log_input | bool %}
{% for input in beats_filebeat_log_inputs %}
- type: filestream
  id: {{ input }}
  enabled: true
  paths:
{% for path in beats_filebeat_log_inputs[input].paths %}
    - {{ path }}
{% endfor %}
{% if beats_fields is defined or beats_filebeat_log_inputs[input].fields is defined %}
  fields:
{% if beats_fields is defined %}
{% for field in beats_fields %}
    {{ field }}
{% endfor %}
{% endif %}
{% if beats_filebeat_log_inputs[input].fields is defined %}
{% for field in beats_filebeat_log_inputs[input].fields %}
    {{ field }}: {{ beats_filebeat_log_inputs[input].fields[field] }}
{% endfor %}
{% endif %}
{% endif %}
{% if beats_filebeat_log_inputs[input].multiline is defined %}
  parsers:
    - multiline:
{% if beats_filebeat_log_inputs[input].multiline.type is defined %}
        type: {{ beats_filebeat_log_inputs[input].multiline.type }}
{% endif %}
{% if beats_filebeat_log_inputs[input].multiline.pattern is defined %}
        pattern: '{{ beats_filebeat_log_inputs[input].multiline.pattern }}'
{% endif %}
{% if beats_filebeat_log_inputs[input].multiline.negate is defined %}
        negate: {{ beats_filebeat_log_inputs[input].multiline.negate }}
{% endif %}
{% if beats_filebeat_log_inputs[input].multiline.match is defined %}
        match: {{ beats_filebeat_log_inputs[input].multiline.match }}
{% endif %}
{% endif %}

{% endfor %}
{% endif %}
{% if beats_filebeat_mysql_slowlog_input | bool %}
- type: filestream
  id: mysql-slowlog
  enabled: true
  paths:
    - /var/log/mysql/*-slow.log
  parsers:
    - multiline:
        pattern: '^\#[[:space:]]Time'
        negate: true
        match: after
  fields:
    mysql:
      logtype: slowquery
  fields_under_root: true
{% endif %}
{% if beats_filebeat_syslog_tcp | bool %}
- type: tcp
  enabled: true
  max_message_size: 10MiB
  host: "0.0.0.0:{{ beats_filebeat_syslog_tcp_port }}"
{% if beats_filebeat_syslog_tcp_ssl | bool %}
  ssl.enabled: true
  ssl.certificate_authorities: ["{{ beats_tls_cacert }}"]
  ssl.certificate: {{ beats_tls_cert }}
  ssl.key: {{ beats_tls_key }}
  ssl.key_passphrase: {{ beats_tls_key_passphrase }}
  ssl.verification_mode: full
{% endif %}
{% if beats_fields is defined or beats_filebeat_syslog_tcp_fields %}
  fields:
{% if beats_fields is defined %}
{% for field in beats_fields %}
    {{ field }}
{% endfor %}
{% endif %}
{% for field in beats_filebeat_syslog_tcp_fields %}
    {{ field }}: {{ beats_filebeat_syslog_tcp_fields[field] }}
{% endfor %}
{% endif %}

{% endif %}
{% if beats_filebeat_syslog_udp | bool %}
- type: udp
  enabled: true
  max_message_size: 10MiB
  host: "0.0.0.0:{{ beats_filebeat_syslog_udp_port }}"
{% if beats_fields is defined or beats_filebeat_syslog_udp_fields %}
  fields:
{% if beats_fields is defined %}
{% for field in beats_fields %}
    {{ field }}
{% endfor %}
{% endif %}
{% for field in beats_filebeat_syslog_udp_fields %}
    {{ field }}: {{ beats_filebeat_syslog_udp_fields[field] }}
{% endfor %}
{% endif %}

{% endif %}
{% if beats_filebeat_journald | bool %}
{% for journald in beats_filebeat_journald_inputs %}
- type: journald
  id: {{ beats_filebeat_journald_inputs[journald].id }}
{% if beats_filebeat_journald_inputs[journald].include_matches is defined %}
  include_matches:
{% for include_match in beats_filebeat_journald_inputs[journald].include_matches %}
    - {{ beats_filebeat_journald_inputs[journald].include_matches[include_match] }}
{% endfor %}
{% endif %}

{% endfor %}
{% endif %}
{% if beats_filebeat_docker | bool %}
- type: filestream
  id: docker-containers
  enabled: true
{% if beats_filebeat_docker_ids == "*" %}
  paths:
    - /var/lib/docker/containers/*/*.log
{% else %}
  paths:
    - /var/lib/docker/containers/{{ beats_filebeat_docker_ids }}/*.log
{% endif %}
  prospector.scanner.symlinks: true
  parsers:
    - container: ~

{% endif %}
{% for input in beats_filebeat_extra_inputs %}
- {{ input | to_nice_yaml(indent=2) | indent(2) | trim }}

{% endfor %}
filebeat.config.modules:
  path: ${path.config}/modules.d/*.yml
  reload.enabled: false
setup.template.settings:
  index.number_of_shards: 1
setup.kibana:
{% if elasticstack_full_stack | default(false) | bool and groups[elasticstack_kibana_group_name] | default([]) | length > 0 %}
  host: "http://{{ groups[elasticstack_kibana_group_name][0] }}:{{ elasticstack_kibana_port }}"
{% endif %}
{% set _beat_output = beats_filebeat_output %}
{% set _beat_loadbalance = beats_filebeat_loadbalance %}
{% set _beat_name = "filebeat" %}
{% include '_beats_output.j2' %}
{% if beats_filebeat_output == "file" %}
output.file:
  path: {{ beats_filebeat_output_file_path | default("/tmp/filebeat-output") }}
  filename: filebeat
{% endif %}

{% include '_beats_logging.j2' %}

queue.{{ beats_queue_type }}:
{% if beats_queue_type == "disk" %}
{% if beats_queue_disk_path %}
  path: {{ beats_queue_disk_path }}
{% endif %}
  max_size: {{ beats_queue_disk_max_size }}
{% endif %}

processors:
  - add_host_metadata: ~
  - add_cloud_metadata: ~
{% if beats_filebeat_docker | bool %}
  - add_docker_metadata: ~
{% endif %}

monitoring:
  enabled: {{ beats_filebeat_elastic_monitoring | bool }}
