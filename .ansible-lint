---
exclude_paths:
  - .ansible/
  - .venv/
  - venv/
  - molecule/shared/
  - mkdocs.yml
  - docs/

warn_list:
  - experimental
  - key-order[task]
  - name[casing]
  - name[missing]
  - package-latest
  - schema[meta]

skip_list:
  - command-instead-of-module
  - galaxy[no-changelog]
  - line-length
  - no-handler
  - package-latest
  - role-name
  - yaml
